<div class="mb-8">
    <h2 class="text-xl font-bold text-text mb-4">
        @T["Additional Content"]
    </h2>
    <div class="space-y-3">
        <div class="bg-accent p-4 rounded-lg border border-primary/10">
            @foreach (var shape in Model)
            {
                @await DisplayAsync(shape)
            }
        </div>
    </div>
</div>